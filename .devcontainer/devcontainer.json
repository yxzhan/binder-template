{
  "name": "ROS2 Jazzy JupyterLab",
  "build": {
    "context": "..",
    "dockerfile": "../binder/Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    }
  },
  "portsAttributes": {
    "8888": {
      "label": "JupyterLab",
      "onAutoForward": "openPreview"
    },
    "9090": {
      "label": "ROS Bridge",
      "onAutoForward": "silent"
    }
  },
  "forwardPorts": [8888, 9090],
  "containerEnv": {
    "REPO_DIR": "/home/repo",
    "CODE_WORKING_DIRECTORY": "/home/repo"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postAttachCommand": "bash .devcontainer/post-attach.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-ros.vscode-ros2",
        "anthropic.claude-code"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/ros2/bin/python",
        "jupyter.defaultKernel": "Python 3",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "runArgs": [
    "--network=host"
  ],
  "remoteUser": "root"
}
